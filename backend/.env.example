# PostgreSQL connection string (Supabase → Project Settings → Database → URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase project URL (Supabase → Project Settings → API)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Supabase service role key — never expose this to the frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI API key for the Socratic tutor
OPENAI_API_KEY=sk-...

# Optional: override AI model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Allowed frontend origin (comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# Server port (default: 3001)
# PORT=3001

# Stripe (optional — billing features are disabled without these)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_MONTHLY_PRICE_ID=price_...    ($12/month)
# STRIPE_YEARLY_PRICE_ID=price_...     ($99/year)
